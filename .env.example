# Copy to .env and fill. .env is gitignored — never commit real secrets.

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres
DATABASE_URL=postgresql://pcs:pcs@localhost:5432/pcs

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=program-capacity-service
KAFKA_GROUP_ID=pcs-treasury-consumer
KAFKA_TREASURY_TOPIC=treasury.capacity.events
KAFKA_DLQ_TOPIC=treasury.capacity.dlq

# Auth (JWT)
JWT_SECRET=change-me-in-real-life
JWT_ISSUER=program-capacity-service
JWT_AUDIENCE=pcs-clients
JWT_EXPIRES_IN=3600s
